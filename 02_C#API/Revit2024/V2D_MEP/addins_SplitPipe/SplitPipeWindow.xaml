<Window x:Class="AlphaBIM.SplitPipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Pipe" Width="400" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#12121C"
        ResizeMode="NoResize"
        Topmost="True">

    <Window.Resources>
        <!-- Primary Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#6366F1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3730A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost Button -->
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" BorderBrush="#374151" BorderThickness="1" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E1E30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#818CF8"/>
            <Setter Property="SelectionBrush" Value="#4F46E5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RadioButton -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- CheckBox -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="20,14">
            <StackPanel>
                <TextBlock Text="✂  SPLIT PIPE" FontSize="15" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#818CF8"/>
                <TextBlock x:Name="txb_pipeInfo" Text="Chưa chọn pipe"
                           FontSize="11" FontFamily="Segoe UI" Foreground="#475569"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── CONTENT ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16">

                <!-- Pick Pipe -->
                <Button x:Name="btn_pickPipe" Content="🎯   PICK PIPE"
                        Style="{StaticResource GhostBtn}"
                        Height="38" Margin="0,0,0,16"
                        Click="BtnPickPipe_Click"/>

                <Separator Background="#2A2A3E" Margin="0,0,0,16"/>

                <!-- Input Parameters -->
                <TextBlock Text="INPUT PARAMETERS" Style="{StaticResource SectionLbl}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LENGTH (mm)" Style="{StaticResource FieldLbl}"/>
                        <TextBox x:Name="txb_Length" Text="3000" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="K  (số đoạn tối đa)" Style="{StaticResource FieldLbl}"/>
                        <TextBox x:Name="txb_K" Text="1000" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#2A2A3E" Margin="0,0,0,16"/>

                <!-- Sort Options -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SORT CONNECTOR BY" Style="{StaticResource SectionLbl}"/>
                        <RadioButton x:Name="rbt_pX" Content="  pX" GroupName="Axis"
                                     IsChecked="True" Style="{StaticResource DarkRadio}"/>
                        <RadioButton x:Name="rbt_pY" Content="  pY" GroupName="Axis"
                                     Style="{StaticResource DarkRadio}"/>
                        <RadioButton x:Name="rbt_pZ" Content="  pZ" GroupName="Axis"
                                     Style="{StaticResource DarkRadio}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DIRECTION" Style="{StaticResource SectionLbl}"/>
                        <RadioButton x:Name="rbt_sortByMin" Content="  From Min" GroupName="Direction"
                                     IsChecked="True" Style="{StaticResource DarkRadio}"/>
                        <RadioButton x:Name="rbt_sortByMax" Content="  From Max" GroupName="Direction"
                                     Style="{StaticResource DarkRadio}"/>
                    </StackPanel>
                </Grid>

                <Separator Background="#2A2A3E" Margin="0,0,0,14"/>

                <!-- Create Flange -->
                <CheckBox x:Name="chk_createFlange"
                          Content="  Tạo mặt bích (Union Fitting) tại điểm cắt"
                          Style="{StaticResource DarkCheck}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── FOOTER ── -->
        <Border Grid.Row="2" Background="#1A1A2E" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="@FVC  AlphaBIM"
                           Foreground="#334155" FontSize="10"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Button Grid.Column="2" x:Name="btn_SPLIT" Content="SPLIT"
                        Style="{StaticResource PrimaryBtn}" Width="88" Height="34"
                        Click="BtnSplit_Click"/>
                <Button Grid.Column="4" x:Name="btn_CANCEL" Content="CANCEL"
                        Style="{StaticResource DangerBtn}" Width="88" Height="34"
                        Click="BtnCancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
