        form = MainForm(data)
        Application.Run(form)
        if form.user_cancelled:
            break
        # pick object, process...
        try:
            ref = uidoc.Selection.PickObject(ObjectType.Element, filter, "Pick...")
            # ...
        except Autodesk.Revit.Exceptions.OperationCanceledException:
            pass  # ESC → quay về UI
        except Exception as ex:
            show_error(str(ex))

main()
