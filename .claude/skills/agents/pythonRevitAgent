def get_connector_list(element):
    """Lấy list connectors từ pipe hoặc fitting."""
    try:
        return list(element.MEPModel.ConnectorManager.Connectors)
    except:
        return list(element.ConnectorManager.Connectors)

def find_nearest_connector(element, xyz_point):
    """Tìm connector gần nhất với xyz_point."""
    conn_list = get_connector_list(element)
    conn_list.sort(key=lambda c: c.Origin.DistanceTo(xyz_point))
    return conn_list[0] if conn_list else None

def connect_two_connectors(conn_a, conn_b):
    """Kết nối 2 connector với nhau."""
    try:
        conn_a.ConnectTo(conn_b)
        return True
    except:
        return False
