## 11. EXCEL INTEGRATION (IronPython)

```python
def get_hidden_excel(file_path):
    """Mở Excel ẩn, trả về (excel, workbook)."""
    excel_type = System.Type.GetTypeFromProgID("Excel.Application")
    if excel_type is None:
        raise Exception("Excel is not installed.")
    excel = System.Activator.CreateInstance(excel_type)
    excel.Visible        = False
    excel.ScreenUpdating = False
    excel.DisplayAlerts  = False
    try:
        workbook = excel.Workbooks.Open(file_path)
        return excel, workbook
    except Exception as ex:
        try: excel.Quit()
        except: pass
        raise ex

def read_excel_sheet(file_path, sheet_name):
    """
    Đọc sheet trong Excel, trả về (headers, data) hoặc (None, error_msg).
    headers: list of str
    data:    list of dict {header: value}
    """
    excel = workbook = None
    try:
        excel, workbook = get_hidden_excel(file_path)
        sheet = None
        for i in range(1, workbook.Worksheets.Count + 1):
            if str(workbook.Worksheets(i).Name) == str(sheet_name):
                sheet = workbook.Worksheets(i)
                break
        if sheet is None:
            return None, "Sheet '%s' not found." % sheet_name

        used = sheet.UsedRange
        last_row = used.Rows.Count
        last_col = used.Columns.Count

        headers = []
        for c in range(1, last_col + 1):
            cell = sheet.Cells(1, c)
            val = cell.Value2
            headers.append(unicode(val) if val is not None else "Col_%d" % c)

        data = []
        for r in range(2, last_row + 1):
            row = {}
            for idx, h in enumerate(headers):
                cell = sheet.Cells(r, idx + 1)
                row[h] = cell.Value2
            data.append(row)

        return headers, data
    except Exception as ex:
        return None, str(ex)
    finally:
        if workbook:
            try: workbook.Close(False)
            except: pass
        if excel:
            try: excel.Quit()
            except: pass

def open_excel_dialog():
    """Hiển thị OpenFileDialog chọn file Excel."""
    dlg = OpenFileDialog()
    dlg.Multiselect = False
    dlg.Filter      = "Excel Files (*.xlsx)|*.xlsx"
    dlg.Title       = "Select Excel File"
    if dlg.ShowDialog() == DialogResult.OK:
        return dlg.FileName
    return None

def get_sheet_names(file_path):
    """Lấy danh sách tên sheet từ Excel file."""
    excel = workbook = None
    try:
        excel, workbook = get_hidden_excel(file_path)
        names = []
        for i in range(1, workbook.Worksheets.Count + 1):
            names.append(unicode(workbook.Worksheets(i).Name))
        return names
    except:
        return []
    finally:
        if workbook:
            try: workbook.Close(False)
            except: pass
        if excel:
            try: excel.Quit()
            except: pass
