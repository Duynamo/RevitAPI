## 10. PIPE CREATION

```python
# Tạo Pipe mới
def create_pipe(doc, system_type_id, pipe_type_id, level_id,
                start_xyz, end_xyz, diameter_feet=None):
    """Tạo một đoạn pipe từ start đến end."""
    pipe = Autodesk.Revit.DB.Plumbing.Pipe.Create(
        doc, system_type_id, pipe_type_id, level_id,
        start_xyz, end_xyz)
    if diameter_feet is not None:
        p = pipe.get_Parameter(BuiltInParameter.RBS_PIPE_DIAMETER_PARAM)
        if p and not p.IsReadOnly:
            p.Set(diameter_feet)
    return pipe

# Tạo Elbow giữa 2 connector
def create_elbow(doc, conn_a, conn_b):
    """Tạo elbow fitting giữa 2 connectors."""
    try:
        fitting = doc.Create.NewElbowFitting(conn_a, conn_b)
        return fitting
    except Exception as ex:
        return None

# Break pipe tại điểm
def break_pipe_at_point(doc, pipe, break_point):
    """Chia pipe thành 2 đoạn tại break_point. Trả về element id của đoạn mới."""
    import Autodesk.Revit.DB.Plumbing as Plumbing
    new_id = Plumbing.PlumbingUtils.BreakCurve(doc, pipe.Id, break_point)
    return doc.GetElement(new_id)
