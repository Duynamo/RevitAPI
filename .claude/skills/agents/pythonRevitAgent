class PipeSelectionFilter(ISelectionFilter):
    """Chỉ cho chọn Pipe."""
    def AllowElement(self, elem):
        return isinstance(elem, Pipe)
    def AllowReference(self, ref, pos):
        return False

class CategorySelectionFilter(ISelectionFilter):
    """Cho chọn theo tên category."""
    def __init__(self, category_names):
        self.category_names = category_names  # list of str
    def AllowElement(self, element):
        if element.Category is None:
            return False
        return element.Category.Name in self.category_names
    def AllowReference(self, ref, pos):
        return False

