## 7. PARAMETER PATTERNS

```python
# Đọc parameter
def get_param_value(element, param_name):
    """Trả về giá trị string của parameter, None nếu không tìm thấy."""
    p = element.LookupParameter(param_name)
    if not p:
        elem_type = doc.GetElement(element.GetTypeId())
        if elem_type:
            p = elem_type.LookupParameter(param_name)
    if not p:
        return None
    if p.StorageType == StorageType.String:
        return p.AsString()
    elif p.StorageType == StorageType.Double:
        return p.AsDouble()
    elif p.StorageType == StorageType.Integer:
        return p.AsInteger()
    elif p.StorageType == StorageType.ElementId:
        return p.AsElementId()
    return None

# Ghi parameter
def set_param_value(element, param_name, value):
    """Ghi giá trị vào parameter. Trả về (True, msg) hoặc (False, err)."""
    try:
        p = element.LookupParameter(param_name)
        if not p:
            elem_type = doc.GetElement(element.GetTypeId())
            if elem_type:
                p = elem_type.LookupParameter(param_name)
        if not p:
            return False, "Parameter '%s' not found" % param_name
        if p.IsReadOnly:
            return False, "Parameter '%s' is read-only" % param_name
        if isinstance(value, str):
            p.Set(value)
        elif isinstance(value, float):
            p.Set(value)
        elif isinstance(value, int):
            p.Set(value)
        return True, "OK"
    except Exception as ex:
        return False, str(ex)

# BuiltInParameter thường dùng
# RBS_PIPE_DIAMETER_PARAM        → đường kính pipe (double, feet)
# RBS_PIPING_SYSTEM_TYPE_PARAM   → system type id
# RBS_START_LEVEL_PARAM          → level của pipe
# LEVEL_PARAM                    → level của element
# WALL_BASE_CONSTRAINT           → base constraint
# INSTANCE_REFERENCE_LEVEL_PARAM → reference level
# FAMILY_LEVEL_PARAM             → family level
# SYMBOL_FAMILY_NAME_PARAM       → family name
# SYMBOL_NAME_PARAM              → type name
